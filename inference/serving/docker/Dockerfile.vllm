FROM vllm/vllm-openai:latest

ENV HOST=0.0.0.0
ENV PORT=8000
ENV API_KEY=local-dev-key
ENV MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
ENV SERVED_MODEL_NAME=local-model
ENV GPU_MEMORY_UTILIZATION=0.90
ENV MAX_MODEL_LEN=8192
ENV MAX_NUM_SEQS=128
ENV TENSOR_PARALLEL_SIZE=1

EXPOSE 8000

CMD ["bash", "-lc", "vllm serve ${MODEL_NAME} --host ${HOST} --port ${PORT} --api-key ${API_KEY} --served-model-name ${SERVED_MODEL_NAME} --gpu-memory-utilization ${GPU_MEMORY_UTILIZATION} --max-model-len ${MAX_MODEL_LEN} --max-num-seqs ${MAX_NUM_SEQS} --tensor-parallel-size ${TENSOR_PARALLEL_SIZE}"]
