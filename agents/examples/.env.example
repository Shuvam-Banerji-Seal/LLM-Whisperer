# LangChain Agent Examples - Environment Variables
# Copy this file to .env and fill in your actual credentials

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Tavily Search API (optional, for research agent)
TAVILY_API_KEY=your-tavily-api-key-here

# Alternative LLM Providers (optional)
# For Anthropic
# ANTHROPIC_API_KEY=your-key-here

# For Cohere
# COHERE_API_KEY=your-key-here

# For Groq (mentioned in documentation)
# GROQ_API_KEY=your-key-here

# For Google VertexAI
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Vector Store Configuration (optional)
CHROMA_COLLECTION_NAME=conversation_history
CHROMA_PERSIST_DIR=./data/memory_store

# Logging Configuration (optional)
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Agent Configuration (optional)
AGENT_TEMPERATURE=0.7
AGENT_MODEL=gpt-3.5-turbo
MEMORY_WINDOW_SIZE=5

# Feature Flags (optional)
ENABLE_LONG_TERM_MEMORY=true
ENABLE_VECTOR_STORE=true
ENABLE_RESEARCH_CACHING=true
